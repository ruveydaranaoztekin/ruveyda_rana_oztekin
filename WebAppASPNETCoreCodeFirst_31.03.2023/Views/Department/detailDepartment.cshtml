@using WebAppCoreMVCCodeFirst._24._03._2023_22.Models
@model Department
@{
    ViewData["Title"] = "Departman Detayı";
    Layout = "~/Views/Shared/_MainLayOutView.cshtml";
}

<div class="container mt-5">

    {{/* Breadcrumb */}}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Department" asp-action="Index">Departmanlar</a>
            </li>
            <li class="breadcrumb-item active">Detay</li>
        </ol>
    </nav>

    {{/* Departman bilgi kartı */}}
    <div class="card border shadow-sm rounded-3 mb-4">
        <div class="card-body d-flex gap-5">
            <div>
                <p class="text-muted small mb-1">Departman ID</p>
                <p class="fw-semibold mb-0">#@Model.DeptID</p>
            </div>
            <div>
                <p class="text-muted small mb-1">Departman adı</p>
                <p class="fw-semibold mb-0">@Model.DeptName</p>
            </div>
        </div>
    </div>

    {{/* Öğrenci listesi */}}
    <p class="text-muted small text-uppercase mb-3" style="letter-spacing:0.05em;">
        Bu departmandaki öğrenciler
    </p>

    @if (Model.Students == null || !Model.Students.Any())
    {
        <div class="text-center py-5 text-muted border rounded-3">
            <i class="bi bi-people fs-1 d-block mb-2"></i>
            Bu departmanda henüz öğrenci bulunmuyor.
        </div>
    }
    else
    {
        <div class="card border shadow-sm rounded-3">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted fw-normal small">Öğrenci no</th>
                            <th class="py-3 text-muted fw-normal small">Ad</th>
                            <th class="py-3 text-muted fw-normal small">Soyad</th>
                            <th class="py-3 text-muted fw-normal small">E-posta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Students)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@s.StudentdsNo</td>
                                <td>@s.StudentdsName</td>
                                <td>@s.StudentdsSurname</td>
                                <td class="text-muted">@s.EMail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 py-2 border-top text-muted small">
                @Model.Students.Count öğrenci
            </div>
        </div>
    }

    <a asp-controller="Department" asp-action="Index" class="btn btn-outline-secondary mt-4">
        <i class="bi bi-arrow-left"></i> Geri dön
    </a>

</div>