@using WebAppCoreMVCCodeFirst._24._03._2023_22.Models
@{
    ViewData["Title"] = "Departman Yönetimi";
    Layout = "~/Views/Shared/_MainLayOutView.cshtml";
}
@model List<Department>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <p class="text-muted small text-uppercase mb-1" style="letter-spacing:0.05em;">Yönetim paneli</p>
            <h2 class="fw-semibold mb-0">Departman yönetimi</h2>
            <p class="text-muted mb-0">Sistemdeki tüm departmanları buradan yönetebilirsiniz.</p>
        </div>
        <a href="/Department/newDepartment" class="btn btn-outline-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Yeni departman
        </a>
    </div>

    <div class="card border shadow-sm rounded-3">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Henüz kayıtlı departman bulunmuyor.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted fw-normal small">ID</th>
                            <th class="py-3 text-muted fw-normal small">Departman adı</th>
                            <th class="text-end pe-4 py-3 text-muted fw-normal small">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@x.DeptID</td>
                                <td class="fw-semibold">@x.DeptName</td>
                                <td class="text-end pe-4">
                                    <a href="/Department/detailDepartment/@x.DeptID" class="btn btn-sm btn-outline-secondary me-1">Detay</a>
                                    <a href="/Department/updateDepartment/@x.DeptID" class="btn btn-sm btn-outline-warning me-1">Düzenle</a>
                                    <a href="/Department/removeDepartment/@x.DeptID"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('@x.DeptName departmanını silmek istediğinizden emin misiniz?');">Sil</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 py-2 border-top text-muted small">@Model.Count departman listeleniyor</div>
        }
    </div>
</div>