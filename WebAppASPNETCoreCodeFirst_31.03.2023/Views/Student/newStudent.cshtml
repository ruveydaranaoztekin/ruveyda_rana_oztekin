@using WebAppCoreMVCCodeFirst._24._03._2023_22.Models
@{
    ViewData["Title"] = "Yeni Öğrenci";
    Layout = "~/Views/Shared/_MainLayOutView.cshtml";
}

<div class="container mt-5" style="max-width: 540px;">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Student" asp-action="Index">Öğrenciler</a>
            </li>
            <li class="breadcrumb-item active">Yeni öğrenci</li>
        </ol>
    </nav>

    <div class="card border shadow-sm rounded-3">
        <div class="card-body p-4">
            <h5 class="fw-semibold mb-1">Yeni öğrenci ekle</h5>
            <p class="text-muted small mb-4">Formu doldurarak sisteme yeni öğrenci ekleyin.</p>

            <form method="post" asp-controller="Student" asp-action="newStudent">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label small text-muted">Öğrenci no</label>
                    <input type="text" name="StudentdsNo" class="form-control" placeholder="örn. 20190101" />
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Ad</label>
                    <input type="text" name="StudentdsName" class="form-control" placeholder="örn. Ayşe" />
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Soyad</label>
                    <input type="text" name="StudentdsSurname" class="form-control" placeholder="örn. Kaya" />
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">E-posta</label>
                    <input type="email" name="EMail" class="form-control" placeholder="örn. ayse@example.com" />
                </div>
                <div class="mb-4">
                    <label class="form-label small text-muted">Departman</label>
                    <select name="DepartmentID" class="form-select">
                        <option value="">-- Departman seçin --</option>
                        @foreach (var dept in ViewBag.Departments)
                        {
                            <option value="@dept.DeptID">@dept.DeptName</option>
                        }
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Kaydet
                    </button>
                    <a asp-controller="Student" asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>

</div>