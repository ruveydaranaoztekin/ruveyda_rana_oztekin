@using WebAppCoreMVCCodeFirst._24._03._2023_22.Models
@model Student
@{
    ViewData["Title"] = "Öğrenci Detayı";
    Layout = "~/Views/Shared/_MainLayOutView.cshtml";
}

<div class="container mt-5" style="max-width: 580px;">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Student" asp-action="Index">Öğrenciler</a>
            </li>
            <li class="breadcrumb-item active">Detay</li>
        </ol>
    </nav>

    <div class="card border shadow-sm rounded-3">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                     style="width:52px; height:52px;">
                    <i class="bi bi-person fs-4 text-primary"></i>
                </div>
                <div>
                    <h5 class="fw-semibold mb-0">@Model.StudentdsName @Model.StudentdsSurname</h5>
                    <p class="text-muted small mb-0">#@Model.StudentdsNo</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-6">
                    <p class="text-muted small mb-1">Öğrenci no</p>
                    <p class="fw-semibold mb-0">@Model.StudentdsNo</p>
                </div>
                <div class="col-6">
                    <p class="text-muted small mb-1">E-posta</p>
                    <p class="fw-semibold mb-0">@Model.EMail</p>
                </div>
                <div class="col-6">
                    <p class="text-muted small mb-1">Departman</p>
                    <p class="fw-semibold mb-0">
                        @(Model.Department?.DeptName ?? "Atanmamış")
                    </p>
                </div>
            </div>
        </div>
    </div>

    <a asp-controller="Student" asp-action="Index" class="btn btn-outline-secondary mt-4">
        <i class="bi bi-arrow-left"></i> Geri dön
    </a>

</div>